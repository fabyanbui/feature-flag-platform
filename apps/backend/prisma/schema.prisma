generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FeatureFlagLifecycleStatus {
  ACTIVE
  ARCHIVED
}

enum FlagConfigStatus {
  ENABLED
  DISABLED
}

enum ServingMode {
  GLOBAL_ON
  TARGETED
}

enum RuleType {
  USER_ALLOWLIST
  ROLE_TARGETING
  PERCENTAGE_ROLLOUT
}

enum AuditTargetType {
  PROJECT
  ENVIRONMENT
  FEATURE_FLAG
  FLAG_GROUP
  FLAG_CONFIG
  FLAG_RULE
  SAMPLE_USER
}

enum AuditAction {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED

  ENVIRONMENT_CREATED
  ENVIRONMENT_UPDATED
  ENVIRONMENT_DELETED

  FEATURE_FLAG_CREATED
  FEATURE_FLAG_UPDATED
  FEATURE_FLAG_ARCHIVED
  FEATURE_FLAG_RESTORED
  FEATURE_FLAG_DELETED
  FEATURE_FLAG_GROUP_ASSIGNED
  FEATURE_FLAG_GROUP_UNASSIGNED

  FLAG_GROUP_CREATED
  FLAG_GROUP_UPDATED
  FLAG_GROUP_DELETED
  FLAG_GROUP_KILL_SWITCH_UPDATED

  FLAG_CONFIG_CREATED
  FLAG_CONFIG_UPDATED
  FLAG_CONFIG_DELETED

  FLAG_RULE_CREATED
  FLAG_RULE_UPDATED
  FLAG_RULE_DELETED
  FLAG_RULES_REPLACED

  SAMPLE_USER_CREATED
  SAMPLE_USER_DELETED
}

model Project {
  id          String    @id @default(cuid())
  key         String    @unique @db.VarChar(64)
  name        String    @db.VarChar(120)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") @db.VarChar(120)

  environments       Environment[]
  flags              FeatureFlag[]
  flagGroups         FlagGroup[]
  flagGroupConfigs   FlagGroupConfig[]
  flagConfigs        FlagEnvironmentConfig[] @relation("ProjectFlagConfigs")
  sampleUserContexts SampleUserContext[]
  auditLogEntries    AuditLogEntry[]
  evaluationMetrics  FlagEvaluationMetric[]

  @@index([deletedAt])
  @@map("projects")
}

model Environment {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  key         String   @db.VarChar(64)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flagConfigs       FlagEnvironmentConfig[]
  flagGroupConfigs  FlagGroupConfig[]
  auditLogEntries   AuditLogEntry[]
  evaluationMetrics FlagEvaluationMetric[]

  @@unique([projectId, key])
  @@unique([projectId, id])
  @@index([projectId])
  @@index([projectId, isDefault])
  @@map("environments")
}

model FeatureFlag {
  id              String                     @id @default(cuid())
  projectId       String                     @map("project_id")
  groupId         String?                    @map("group_id")
  key             String                     @db.VarChar(64)
  name            String                     @db.VarChar(120)
  description     String?                    @db.Text
  lifecycleStatus FeatureFlagLifecycleStatus @default(ACTIVE) @map("lifecycle_status")
  archivedAt      DateTime?                  @map("archived_at")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  deletedAt       DateTime?                  @map("deleted_at")
  deletedBy       String?                    @map("deleted_by") @db.VarChar(120)

  project            Project                 @relation(fields: [projectId], references: [id], onDelete: Restrict)
  group              FlagGroup?              @relation(fields: [projectId, groupId], references: [projectId, id], onDelete: Restrict)
  environmentConfigs FlagEnvironmentConfig[]
  evaluationMetrics  FlagEvaluationMetric[]

  @@unique([projectId, key])
  @@unique([projectId, id])
  @@index([projectId])
  @@index([projectId, lifecycleStatus])
  @@index([projectId, deletedAt])
  @@index([groupId])
  @@map("feature_flags")
}

model FlagGroup {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  key       String   @db.VarChar(64)
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  flags   FeatureFlag[]
  configs FlagGroupConfig[]

  @@unique([projectId, key])
  @@unique([projectId, id])
  @@index([projectId])
  @@map("flag_groups")
}

model FlagGroupConfig {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  groupId       String   @map("group_id")
  environmentId String   @map("environment_id")
  killSwitch    Boolean  @default(false) @map("kill_switch")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  group       FlagGroup   @relation(fields: [projectId, groupId], references: [projectId, id], onDelete: Cascade)
  environment Environment @relation(fields: [projectId, environmentId], references: [projectId, id], onDelete: Restrict)

  @@unique([groupId, environmentId])
  @@index([projectId, environmentId])
  @@index([groupId])
  @@map("flag_group_configs")
}

model FlagEnvironmentConfig {
  id            String           @id @default(cuid())
  projectId     String           @map("project_id")
  flagId        String           @map("flag_id")
  environmentId String           @map("environment_id")
  status        FlagConfigStatus @default(DISABLED)
  servingMode   ServingMode      @default(TARGETED) @map("serving_mode")
  killSwitch    Boolean          @default(false) @map("kill_switch")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  project     Project     @relation("ProjectFlagConfigs", fields: [projectId], references: [id], onDelete: Restrict)
  flag        FeatureFlag @relation(fields: [projectId, flagId], references: [projectId, id], onDelete: Cascade)
  environment Environment @relation(fields: [projectId, environmentId], references: [projectId, id], onDelete: Restrict)
  rules       FlagRule[]

  @@unique([flagId, environmentId])
  @@index([projectId, environmentId, flagId])
  @@index([environmentId, status])
  @@index([flagId])
  @@map("flag_environment_configs")
}

model FlagRule {
  id           String   @id @default(cuid())
  flagConfigId String   @map("flag_config_id")
  type         RuleType
  priority     Int
  enabled      Boolean  @default(true)
  parameters   Json     @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  flagConfig FlagEnvironmentConfig @relation(fields: [flagConfigId], references: [id], onDelete: Cascade)

  @@unique([flagConfigId, priority])
  @@index([flagConfigId])
  @@index([flagConfigId, type, priority])
  @@map("flag_rules")
}

model FlagEvaluationMetric {
  id String @id @default(cuid())

  projectId     String? @map("project_id")
  environmentId String? @map("environment_id")
  flagId        String? @map("flag_id")

  projectKey     String @map("project_key") @db.VarChar(64)
  environmentKey String @map("environment_key") @db.VarChar(64)
  flagKey        String @map("flag_key") @db.VarChar(64)

  bucketStart DateTime @map("bucket_start") @db.Timestamptz(3)
  reason      String   @db.VarChar(40)
  enabled     Boolean
  count       Int      @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  flag        FeatureFlag? @relation(fields: [flagId], references: [id], onDelete: SetNull)

  @@unique([projectKey, environmentKey, flagKey, bucketStart, reason, enabled], name: "metricBucket", map: "flag_evaluation_metrics_bucket_key")
  @@index([projectKey, environmentKey, bucketStart])
  @@index([projectKey, flagKey, environmentKey, bucketStart])
  @@index([projectId])
  @@index([environmentId])
  @@index([flagId])
  @@map("flag_evaluation_metrics")
}

model SampleUserContext {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  displayName  String   @map("display_name") @db.VarChar(120)
  targetingKey String   @map("targeting_key") @db.VarChar(120)
  userId       String?  @map("user_id") @db.VarChar(120)
  roles        Json     @default("[]") @db.JsonB
  attributes   Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, targetingKey])
  @@index([projectId])
  @@map("sample_user_contexts")
}

model AuditLogEntry {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  projectKey     String          @map("project_key") @db.VarChar(64)
  environmentId  String?         @map("environment_id")
  environmentKey String?         @map("environment_key") @db.VarChar(64)
  targetType     AuditTargetType @map("target_type")
  targetId       String          @map("target_id")
  targetKey      String?         @map("target_key") @db.VarChar(120)
  action         AuditAction
  actor          String          @db.VarChar(120)
  before         Json?           @db.JsonB
  after          Json?           @db.JsonB
  metadata       Json?           @db.JsonB
  requestId      String          @map("request_id") @db.VarChar(120)
  createdAt      DateTime        @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  environment Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([projectKey, createdAt])
  @@index([environmentId, createdAt])
  @@index([projectId, environmentKey, createdAt])
  @@index([projectId, targetType, targetKey, createdAt])
  @@index([projectId, actor, createdAt])
  @@index([projectId, action, createdAt])
  @@map("audit_log_entries")
}
