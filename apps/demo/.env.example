VITE_API_BASE_URL=http://localhost:3000/v1
# Default production demo app. The staging demo script overrides this at runtime.
VITE_ENVIRONMENT_KEY=production
# Optional server-only override for the demo backend. Docker Compose sets this to
# http://backend:3000/v1 so the demo container can reach the platform backend.
# DEMO_SERVER_API_BASE_URL=http://localhost:3000/v1
