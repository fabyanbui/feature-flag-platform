{
  "name": "@ffp/js-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Fail-closed JavaScript SDK for the Feature Flag Platform evaluation API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "prepare": "npm run build",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
