# Set this to a least-privilege GitHub personal access token before starting Codex.
export GITHUB_PAT_TOKEN=replace-with-github-pat

# Optional path to the Chromium executable used by the Playwright MCP server.
# If unset, .codex/config.toml defaults to the ignored repo-local cache:
# .playwright-browsers/chromium-1228/chrome-linux64/chrome
# export CHROMIUM_BROWSER_PATH=/usr/bin/chromium-browser

# Backend API
DATABASE_URL=postgresql://ffp:ffp_dev_password@localhost:5432/ffp_dev?schema=public
# PostgreSQL read-only MCP. Use a separate least-privilege role, not the write-capable app role.
POSTGRES_MCP_DATABASE_URL=postgresql://mcp_reader:change_me@localhost:5432/ffp_dev
API_PORT=3000
ADMIN_ORIGIN=http://localhost:5173
DEMO_ORIGIN=http://localhost:5174
DEMO_STAGING_ORIGIN=http://localhost:5175
# Evaluation configuration snapshots only; final user decisions are not cached.
# Providers: memory (default), none (disabled), or redis (optional Phase 18).
EVALUATION_CACHE_PROVIDER=memory
EVALUATION_CACHE_TTL_MS=30000
# Required only when EVALUATION_CACHE_PROVIDER=redis. Compose resolves the
# service host as redis when the optional redis profile is enabled.
REDIS_URL=redis://localhost:6379
# Presentation-only server-resolved identities. Use unique local values and
# configure matching VITE_DEMO_*_TOKEN values in apps/admin/.env.
DEMO_ADMIN_TOKEN=replace-with-local-admin-demo-token
DEMO_ADMIN_ACTOR=demo-admin
DEMO_DEVELOPER_TOKEN=replace-with-local-developer-demo-token
DEMO_DEVELOPER_ACTOR=demo-developer
DEMO_VIEWER_TOKEN=replace-with-local-viewer-demo-token
DEMO_VIEWER_ACTOR=demo-viewer

# Frontend apps
VITE_API_BASE_URL=http://localhost:3000/v1
VITE_DEFAULT_PROJECT_KEY=demo-project
VITE_DEFAULT_FLAG_KEY=new-checkout
VITE_ENVIRONMENT_KEY=production

# Docker Compose demo workflow
# Host-side PostgreSQL uses 5432 by default. If 5432 is already used by
# another local PostgreSQL, change DATABASE_URL, POSTGRES_MCP_DATABASE_URL,
# and POSTGRES_HOST_PORT to 55432. Containers still use internal postgres:5432.
# Keep DATABASE_URL above for npm-local development. Compose migration, seed,
# and backend containers use the service name "postgres" instead of localhost.
POSTGRES_USER=ffp
POSTGRES_PASSWORD=ffp_dev_password
POSTGRES_DB=ffp_dev
POSTGRES_HOST_PORT=5432
COMPOSE_DATABASE_URL=postgresql://ffp:ffp_dev_password@postgres:5432/ffp_dev?schema=public
BACKEND_HOST_PORT=3000
ADMIN_HOST_PORT=5173
DEMO_HOST_PORT=5174
DEMO_STAGING_HOST_PORT=5175
PRISMA_STUDIO_HOST_PORT=5555
REDIS_HOST_PORT=6379
